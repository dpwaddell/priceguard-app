{% if customer %}
  <script>
    window.PriceGuard = window.PriceGuard || {};
    window.PriceGuard.proxyBase = '/apps/priceguard/price';
    window.PriceGuard.proxySitewideBase = '/apps/priceguard/prices';
    window.PriceGuard.customerLoggedIn = true;
    window.PriceGuard.moneyFormat = {{ shop.money_format | json }};
    window.PriceGuard.customerId = {{ customer.id | json }};
    window.PriceGuard.customerEmail = {{ customer.email | json }};
    window.PriceGuard.customerTags = {{ customer.tags | json }};
    window.PriceGuard.debug = false;
  </script>
  {{ 'priceguard-pricing.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'priceguard-sitewide.js' | asset_url }}" defer></script>
{% endif %}

{% schema %}
{
  "name": "PriceGuard Sitewide",
  "target": "body",
  "settings": []
}
{% endschema %}
